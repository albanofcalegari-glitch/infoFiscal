# .env.example — InfoFiscal
# Copiar como .env y completar los valores reales.
# NUNCA commitear el .env real al repositorio.
#
# Generar SECRET_KEY seguro con:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Base de datos ──────────────────────────────────────────────────────────────
# Desarrollo local (docker-compose):
DATABASE_URL=postgresql://infofiscal:local_dev_only@localhost:5432/infofiscal
# Producción: reemplazar con la URL del proveedor.

# ── Seguridad ──────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Cambiar este valor invalida TODAS las sesiones activas.
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-de-al-menos-32-chars

# ── Sesión ────────────────────────────────────────────────────────────────────
SESSION_HOURS=8

# ── Protección fuerza bruta ────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Flask ─────────────────────────────────────────────────────────────────────
# Valores: development | production
# En production:
#   - Secure=True en cookies (requiere HTTPS)
#   - FLASK_DEBUG deshabilitado automáticamente
FLASK_ENV=development

# ── AFIP (heredado del prototipo — no modificar en esta etapa) ─────────────────
AFIP_ENV=prod
AFIP_CUIT=20321518045
AFIP_CERT_PATH=certs/certificado.crt
AFIP_KEY_PATH=certs/clave_privada.key
